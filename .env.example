# Coolify / Docker Compose environment
DB_DATABASE=taghvim
DB_USERNAME=taghvim
DB_PASSWORD=change-me-strong-password

API_PORT=8000
FRONTEND_PORT=3000

# Public URL of the API (browser-accessible) — must NOT be localhost in production
NEXT_PUBLIC_API_URL=https://api.taghvim.pixlink.ir/api/v1
CORS_ALLOWED_ORIGINS=https://taghvim.pixlink.ir,http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGIN_PATTERNS=#^https://.*\.pixlink\.ir$#
